# Python
__pycache__/
.pytest_cache/
*.py[cod]
*.egg-info/
venv/
.venv/

# Node / Frontend
node_modules/
dist/
.next/
.vite/
*.tsbuildinfo

# Runtime data
runtime_logs/
projects/
/jobs/
demo_output/
voice_bank/
uploads/

# 例外：frontend-next 里的 (app)/projects/ 和 (app)/jobs/ 是 Next.js 路由页面源码，
# 与顶层 runtime 数据目录同名但完全不是同一类东西，必须入库。
!frontend-next/src/app/(app)/projects/
!frontend-next/src/app/(app)/projects/**
!frontend-next/src/app/(app)/jobs/
!frontend-next/src/app/(app)/jobs/**

# Config (secrets)
.env
.env.*
# But keep the (secret-free) template — host-level placeholders, no real values.
!.env.example
autodub.local.json
remote_workbench.local.json
voice_registry.json

# Build artifacts
tools/caddy/
*.tar.gz

