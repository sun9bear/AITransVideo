FROM node:22-alpine AS builder

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .

# Captcha config — baked into the client JS bundle at build time
ARG NEXT_PUBLIC_CAPTCHA_PROVIDER=fake
ARG NEXT_PUBLIC_TURNSTILE_SITE_KEY=
ARG NEXT_PUBLIC_GEETEST_REGISTER_CAPTCHA_ID=
ARG NEXT_PUBLIC_GEETEST_LOGIN_CAPTCHA_ID=
ARG NEXT_PUBLIC_ENABLE_POST_EDIT=0
ARG NEXT_PUBLIC_ENABLE_FREE_TIER=0
ARG NEXT_PUBLIC_SITE_URL=https://aitrans.video
# Paddle.js client-side token + environment — baked into the client bundle so
# /paddle-checkout can Paddle.Initialize(). The client token is browser-safe
# (Paddle designs it to be public); the server API key/webhook secret are NOT
# here. Default env sandbox; production passes NEXT_PUBLIC_PADDLE_ENV=production.
ARG NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
ARG NEXT_PUBLIC_PADDLE_ENV=sandbox
# APF 匿名 Free 预览 (plan 2026-06-10 T1) — 构建期烘焙，默认关
ARG NEXT_PUBLIC_ENABLE_ANONYMOUS_PREVIEW=0
ARG NEXT_PUBLIC_ENABLE_SMART_PREVIEW_CLONE=0
# 界面语言切换器（UI page locale）— 构建期烘焙，默认关：uiloc en 内容补齐前 ship dark
ARG NEXT_PUBLIC_ENABLE_LOCALE_SWITCHER=0
ENV NEXT_PUBLIC_CAPTCHA_PROVIDER=$NEXT_PUBLIC_CAPTCHA_PROVIDER
ENV NEXT_PUBLIC_TURNSTILE_SITE_KEY=$NEXT_PUBLIC_TURNSTILE_SITE_KEY
ENV NEXT_PUBLIC_GEETEST_REGISTER_CAPTCHA_ID=$NEXT_PUBLIC_GEETEST_REGISTER_CAPTCHA_ID
ENV NEXT_PUBLIC_GEETEST_LOGIN_CAPTCHA_ID=$NEXT_PUBLIC_GEETEST_LOGIN_CAPTCHA_ID
ENV NEXT_PUBLIC_ENABLE_POST_EDIT=$NEXT_PUBLIC_ENABLE_POST_EDIT
ENV NEXT_PUBLIC_ENABLE_FREE_TIER=$NEXT_PUBLIC_ENABLE_FREE_TIER
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=$NEXT_PUBLIC_PADDLE_CLIENT_TOKEN
ENV NEXT_PUBLIC_PADDLE_ENV=$NEXT_PUBLIC_PADDLE_ENV
ENV NEXT_PUBLIC_ENABLE_ANONYMOUS_PREVIEW=$NEXT_PUBLIC_ENABLE_ANONYMOUS_PREVIEW
ENV NEXT_PUBLIC_ENABLE_SMART_PREVIEW_CLONE=$NEXT_PUBLIC_ENABLE_SMART_PREVIEW_CLONE
ENV NEXT_PUBLIC_ENABLE_LOCALE_SWITCHER=$NEXT_PUBLIC_ENABLE_LOCALE_SWITCHER

RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ARG NEXT_PUBLIC_ENABLE_FREE_TIER=0
ARG NEXT_PUBLIC_ENABLE_SMART_PREVIEW_CLONE=0
ENV NODE_ENV=production
ENV NEXT_PUBLIC_ENABLE_FREE_TIER=$NEXT_PUBLIC_ENABLE_FREE_TIER
ENV NEXT_PUBLIC_ENABLE_SMART_PREVIEW_CLONE=$NEXT_PUBLIC_ENABLE_SMART_PREVIEW_CLONE
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000
CMD ["node", "server.js"]
