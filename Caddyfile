{
    admin off
}

{$AUTODUB_PUBLIC_HOST} {
    tls internal

    encode zstd gzip

    log {
        output file /var/log/aivideotrans/public-entry.access.log {
            roll_keep 10
            roll_keep_for 168h
        }
        format json
    }

    # Auth is handled by Gateway (session-based), not Caddy basic_auth

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Auth frontend pages → Next.js (must come before auth API catch-all)
    @auth_pages {
        path /auth/login /auth/register /auth/forgot-password
        method GET
    }
    handle @auth_pages {
        reverse_proxy 127.0.0.1:3000
    }

    # Auth API endpoints → Gateway
    @auth_api {
        path /auth/login /auth/logout /auth/register /auth/me /auth/phone/* /auth/captcha/*
    }
    handle @auth_api {
        reverse_proxy 127.0.0.1:8880
    }

    # Other API traffic → Gateway
    @api_routes {
        path /api/*
        path /job-api/*
        path /gateway/*
    }
    handle @api_routes {
        reverse_proxy 127.0.0.1:8880
    }

    # Everything else → Next.js
    handle {
        reverse_proxy 127.0.0.1:3000
    }
}
