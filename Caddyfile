{
    admin off
    # Phase 1 (2026-04-22): Caddy no longer terminates public TLS. Cloudflare
    # edge handles the public cert for aitrans.video; cloudflared-us tunnels
    # to us over the loopback. Caddy only speaks TLS on loopback using its
    # internal CA (Caddy Local Authority). Because every site block below
    # binds to 127.0.0.1 / localhost only, Caddy will NOT attempt ACME for
    # them (non-routable, filtered by Caddy's auto_https safety checks).
    #
    # NOTE: do NOT add `auto_https off` here — that flag turns off Caddy's
    # automatic certificate *management* completely, which also stops the
    # internal CA from minting the localhost cert. Result: TLS handshakes
    # fail with "tlsv1 alert internal error" and the tunnel returns 502.
    # This is a trap v1 of the Phase 1 §14 change hit — see
    # docs/plans/2026-04-21-phase01-implementation-checklist.md note.
}

# Loopback-only listener reached by the cloudflared-us container
# (network_mode: host). Cloudflare Tunnel Public Hostname for
# aitrans.video / app.aitrans.video must point at HTTPS://localhost:443
# with noTLSVerify: true (Caddy serves its internal self-signed cert).
# See docs/plans/2026-04-21-phase01-implementation-checklist.md §14.
#
# aitrans.video must be listed as a site-block matcher because cloudflared
# forwards the public Host header ("aitrans.video") unchanged. Without it,
# Caddy v2 doesn't match any site block for that Host and returns an empty
# 200 default response — trap v2 of §14, manifesting as tunnel → 0-byte
# body. `bind 127.0.0.1` forces loopback binding even though aitrans.video
# resolves via DNS to CF edge IPs. `tls internal` issues internal-CA certs
# for ALL three names (incl. aitrans.video); cloudflared accepts because
# its Public Hostname has `No TLS Verify = ON`.
#
# To revert (撤退预案, plan §11.6):
#   1. put back the `{$AUTODUB_PUBLIC_HOST}` block with `tls {$CADDY_EMAIL}`
#   2. reopen ufw 80/443 on the US host
#   3. DNS: flip aitrans.video back to an A record at the US IP
127.0.0.1:443, localhost:443, aitrans.video:443 {
    bind 127.0.0.1
    tls internal

    encode zstd gzip

    log {
        output file /var/log/aivideotrans/public-entry.access.log {
            roll_keep 10
            roll_keep_for 168h
        }
        format json
    }

    # Auth is handled by Gateway (session-based), not Caddy basic_auth

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Auth frontend pages → Next.js (must come before auth API catch-all)
    @auth_pages {
        path /auth/login /auth/register /auth/forgot-password
        method GET
    }
    handle @auth_pages {
        reverse_proxy 127.0.0.1:3000
    }

    # Auth API endpoints → Gateway
    @auth_api {
        path /auth/login /auth/logout /auth/register /auth/me /auth/phone/* /auth/captcha/*
    }
    handle @auth_api {
        reverse_proxy 127.0.0.1:8880
    }

    # Deny public access to internal-only endpoints (app↔gateway on localhost only).
    # Must come BEFORE @api_routes to short-circuit reverse_proxy.
    # Return 404 (not 403) to avoid confirming endpoint existence (enumeration defense).
    @internal_block {
        path /api/internal/*
    }
    handle @internal_block {
        respond "Not Found" 404
    }

    # Other API traffic → Gateway
    @api_routes {
        path /api/*
        path /job-api/*
        path /gateway/*
    }
    handle @api_routes {
        reverse_proxy 127.0.0.1:8880
    }

    # Everything else → Next.js
    handle {
        reverse_proxy 127.0.0.1:3000
    }
}
