# AIVideoTrans — host-level environment variables for docker-compose.
# Copy to `.env` (gitignored) and fill in real values. Never commit secrets.

# --- Postgres ---
# Required. Used by the `postgres` service (POSTGRES_PASSWORD) and passed to the
# gateway as AVT_PG_PASSWORD so it can build the asyncpg URL.
PG_PASSWORD=

# --- Gateway internal API key (T4) ---
# 32+ char random string. Gateway refuses to start without it (min 16 chars).
# Used to authenticate app <-> gateway loopback calls to /api/internal/*.
# Generate once per deploy and keep stable:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
AVT_INTERNAL_API_KEY=

# --- Deployment environment ---
# "dev" | "test" | "staging" | "prod" | "production".
#
# docker-compose.yml defaults AVT_ENV to "production" when this variable is
# not set, so the startup guard (validate_production_safety) refuses to run
# with AUTH_REQUIRED=false by default. Production deploys should either
# leave this empty (safe default) or set explicitly to "production".
#
# For LOCAL DEV only: uncomment the line below to override with "dev".
# AVT_ENV=dev
#
# Fake payment is for local/test checkout loops. In production it is disabled
# unless explicitly enabled for a controlled smoke test.
AVT_ENABLE_FAKE_PAYMENT=false

# Production should normally keep this false and rely on SITE_URL /
# AVT_CORS_ORIGINS for CSRF same-origin checks. Set true only if Gateway is
# reachable exclusively through a reverse proxy that overwrites X-Forwarded-Host.
AVT_CSRF_TRUST_FORWARDED_HOST=false

# --- Caddy TLS admin contact (Let's Encrypt) ---
# Admin email for ACME account — receives rate-limit + expiration warnings.
# Required on production; Caddy auto-provisions Let's Encrypt certs for
# $AUTODUB_PUBLIC_HOST. Local dev without a public domain can leave empty
# (Caddy will fall back to self-signed for localhost-only testing).
CADDY_EMAIL=

# --- Application path layout ---
# Production defaults (matching docker-compose.yml — both app and gateway
# containers share the same host bind mount tree under /opt/aivideotrans).
# When unset, code falls back to the /opt/aivideotrans/... defaults shown
# below, so production hosts do not have to set these explicitly.
#
# Override these ONLY for local Windows/macOS dev where /opt/aivideotrans
# does not exist. Example:
#   AIVIDEOTRANS_CONFIG_DIR=D:/Claude/AIVideoTrans_Codex_web_mvp/local/config
#   AIVIDEOTRANS_JOBS_DIR=D:/Claude/AIVideoTrans_Codex_web_mvp/local/jobs
#   AIVIDEOTRANS_PROJECTS_DIR=D:/Claude/AIVideoTrans_Codex_web_mvp/local/projects
#   AIVIDEOTRANS_RUNTIME_LOGS_DIR=D:/Claude/AIVideoTrans_Codex_web_mvp/local/runtime_logs
#
# Production (not normally needed — these are the implicit defaults):
# AIVIDEOTRANS_CONFIG_DIR=/opt/aivideotrans/config
# AIVIDEOTRANS_JOBS_DIR=/opt/aivideotrans/app/jobs
# AIVIDEOTRANS_PROJECTS_DIR=/opt/aivideotrans/app/projects
# AIVIDEOTRANS_RUNTIME_LOGS_DIR=/opt/aivideotrans/data/runtime_logs

# --- Customer support (plan 2026-05-08) ---
# All values can be overridden by admin in the support admin page; env var
# values are the boot-time defaults. Defaults below are safe to leave as-is.
#
# Provider must default to "fake" — the AST guard
# tests/test_support_ai_provider_defaults.py enforces this. Real LLM
# only activates when an admin flips both AVT_SUPPORT_AI_ENABLED=true
# AND sets AVT_SUPPORT_AI_PROVIDER to a real provider name AND has the
# corresponding API key (e.g. DEEPSEEK_API_KEY) set.
# Both default OFF for safe rollout (Codex P2-1, 2026-05-08). An operator
# must explicitly flip these to "true" — either via env or via the admin
# support page — before the widget appears. Fresh deploys stay dark.
AVT_SUPPORT_ENABLED=false
AVT_SUPPORT_ANONYMOUS_ENABLED=false
AVT_SUPPORT_AI_PROVIDER=fake
AVT_SUPPORT_AI_ENABLED=false
AVT_SUPPORT_AI_MODEL=deepseek
AVT_SUPPORT_AI_MAX_OUTPUT_TOKENS=400
AVT_SUPPORT_AI_MAX_INPUT_CHARS=2000
AVT_SUPPORT_AI_TIMEOUT_SECONDS=15
AVT_SUPPORT_AI_MONTHLY_BUDGET_USD=50
AVT_SUPPORT_AI_INPUT_USD_PER_1M_TOKENS=0.14
AVT_SUPPORT_AI_OUTPUT_USD_PER_1M_TOKENS=0.28
AVT_SUPPORT_HANDOFF_PROVIDER=email
AVT_SUPPORT_OPS_EMAIL=sxz999@proton.me

# Chatwoot (P3 — not deployed in P1, leave empty)
AVT_CHATWOOT_ENABLED=false
AVT_CHATWOOT_BASE_URL=
AVT_CHATWOOT_ACCOUNT_ID=
AVT_CHATWOOT_INBOX_ID=
AVT_CHATWOOT_API_TOKEN=

# WeChat customer service (P4/P5 — not wired in P1, leave empty)
AVT_WECHAT_KF_ENABLED=false
AVT_WECHAT_KF_CORP_ID=
AVT_WECHAT_KF_SECRET=
AVT_WECHAT_KF_OPEN_KFID=

# --- Studio post-edit feature flag (D29, plan 2026-04-18) ---
# Backend: gates the editing endpoints (enter-edit / editing/cancel /
# editing/commit + segment mutations). When false, gateway returns 404
# for those routes — any user attempt to enter edit mode fails closed.
# Frontend: NEXT_PUBLIC_ENABLE_POST_EDIT must be set to "1" at NEXT
# build time to render the "修改" entry + /workspace/{id}/edit page.
# Both are independent gates. To enable post-edit fully you must flip
# BOTH (backend env AND frontend build-arg). Default off everywhere.
AVT_ENABLE_POST_EDIT=false
NEXT_PUBLIC_ENABLE_POST_EDIT=0

# --- MiMo free-tier feature flag (Phase 2a, plan 2026-05-29) ---
# Backend: gates service_mode="free" job creation (gateway). When false,
# free-mode jobs are rejected — fail closed, never silently downgraded.
# Frontend: NEXT_PUBLIC_ENABLE_FREE_TIER must be "1" at NEXT build time to
# render the free-tier entry. Both default off; flip BOTH to enable.
# ⚠️ LAUNCH GATE: public free tier ALSO requires consent/legal sign-off
# (design §5.3, 《民法典》1023 声音权) — these flags alone do NOT authorize
# opening it to the public.
AVT_ENABLE_FREE_TIER=false
NEXT_PUBLIC_ENABLE_FREE_TIER=0

# --- Phase 2 R2 download backend (plan 2026-04-23) ---
# `local`  → keep existing Gateway → Job-API byte-passthrough (default).
# `r2`     → 302-redirect to a presigned R2 URL when the artifact is
#            already in R2; HEAD 404 triggers lazy upload then redirect.
# Any failure on R2 path falls back to local automatically (gateway
# logs WARNING, user-visible path remains green). All four R2_* secrets
# below MUST be populated for `r2` mode; missing any one triggers
# startup CRITICAL log + auto-downgrade to local.
AVT_DOWNLOAD_REDIRECT_BACKEND=local
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ARTIFACTS_BUCKET=avt-artifacts
# Presigned URL TTL in seconds (default 120s — short on purpose).
AVT_R2_PRESIGNED_EXPIRES_S=120
# Stream presigned URL TTL in seconds. Larger than the download TTL because
# <video> players issue multiple Range requests during playback — 120s would
# 403 mid-play on any video > 2 min. 1800s (30 min) covers a typical scrub
# session. Used by /jobs/{id}/stream/{video|audio|poster} (plan 2026-05-07 §11).
AVT_R2_STREAM_PRESIGNED_EXPIRES_S=1800
# Lazy-upload wall-clock budget in seconds — exceeding falls back to local.
AVT_R2_UPLOAD_TIMEOUT_S=60
# R2 proactive push sweeper. When true (and AVT_DOWNLOAD_REDIRECT_BACKEND=r2),
# the 300s loop scans terminal jobs and pre-pushes artifacts. Default off;
# without R2 mode it's a no-op.
AVT_R2_PROACTIVE_PUSH_ENABLED=false

# --- Voice CPS auto-calibration (plan 2026-05-09 v4.3) ---
# T1 clone-after hook. When true: each successful clone fires 2 background
# tasks (turbo + hd) to populate chars_per_second_by_model. Rate-limited
# to 8/min × 30/day per user. Default ON because clone is itself a paid
# action; keeping calibration in lockstep avoids first-run CPS surprises.
AVT_AUTO_CALIBRATE_AFTER_CLONE=true
# T2 review-submit preflight. When true: /review/voice-selection/approve
# pre-calibrates chosen voices' CPS for the job's final MiniMax model
# before proxying to Job-API (hard 50s upper bound; queued tasks at
# timeout get cancelled, started ones continue in background). Default
# OFF — operator opts in after observing T1 + manual paths.
AVT_AUTO_CALIBRATE_ON_REVIEW_SUBMIT=false

# --- Build-time feature flags (Dockerfile build args, NOT runtime env) ---
# These travel through `docker compose build` build-args; setting them
# at runtime has no effect. Listed here for operator visibility.
# Whisper transcription (gateway side). Default 0 (Whisper not installed).
# Switching to 1 bloats the gateway image by ~2 GB; only enable if you
# truly need on-host Whisper instead of AssemblyAI.
INSTALL_WHISPER=0
# HuggingFace cache dir baked into image. Defaults to /root/.cache/huggingface.
HF_HOME=

# --- Cross-service URL (worker → gateway) ---
# When the Python pipeline (running inside aivideotrans-app) calls back
# into the gateway (e.g. internal /api/internal/voice-catalog lookups),
# code uses 127.0.0.1:8880 by default because both containers share
# host network. Override only if your topology differs (e.g. testing
# against a remote gateway).
# AVT_GATEWAY_URL=http://127.0.0.1:8880

# --- Pan backup (plan 2026-05-14) ---
# Primary feature flag. OFF: all /admin/pan/* endpoints return 404.
AVT_ENABLE_PAN_BACKUP=false

# 30d-auto-archive sub-flag. Independent of main flag.
# Strategy: turn main flag ON first → manual smoke 1 week → flip this for cron.
AVT_PAN_AUTO_ARCHIVE_ENABLED=false
AVT_PAN_AUTO_ARCHIVE_DAYS=30
AVT_PAN_AUTO_ARCHIVE_HOUR_BJT=3
AVT_PAN_AUTO_ARCHIVE_MAX_PER_RUN=5
AVT_PAN_AUTO_ARCHIVE_DRY_RUN=true
AVT_PAN_ORPHAN_CLEANUP_WEEKDAY=5

# Upload + reap params
AVT_PAN_UPLOAD_CHUNK_BYTES=16777216  # 16 MiB. 2026-06-01: was 4 MiB but
# Baidu PCS partseq cap = 2048, so 4 MiB chunks topped out at 8 GB single
# upload (Boris Cherny 8.61 GB / c31b 11 GB both hit it with errno 31299
# "Invalid param part_id"). 16 MiB × 2048 = 32 GB ceiling, covers all
# realistic project sizes. Tunable down for slower links if needed.
AVT_PAN_TASK_STALE_HOURS=4          # heartbeat staleness threshold

# 2026-05-26 postmortem P0b/P0c. Global serialization timeout (seconds)
# for backup_executor's pg_try_advisory_lock polling loop. Default 14400s
# (= 4h, matches pan_task_stale_hours). Lowering for small deployments
# is fine; raising past 4h delays recovery for a permanently-wedged
# executor — stale_reaper can reap the BackupRecord row to 'failed'
# but it cannot release a still-alive PG session-level global lock;
# the lock only frees when the wedged session itself dies (server-side
# idle timeout or `docker restart aivideotrans-gateway`). See
# gateway/config.py for the full rationale.
AVT_PAN_BACKUP_GLOBAL_LOCK_TIMEOUT_S=14400

# Tar staging directory. MUST be a bind mount on the data partition,
# NOT the gateway container's overlay (= host root) — that path was
# the 2026-05-26 disk-full incident vector. docker-compose.yml mounts
# ${AIVIDEOTRANS_ROOT}/data/_pan_tmp → /opt/aivideotrans/data/_pan_tmp
# and points this env there by default. Empty → executor falls back
# to TMPDIR/`/tmp` (only safe for dev/test, NOT production).
AVT_PAN_TMP_DIR=/opt/aivideotrans/data/_pan_tmp

# Free-space preflight ratio: tar.gz needs at least project_dir size
# × ratio free in AVT_PAN_TMP_DIR before tar build starts, else
# executor refuses + rolls back BackupRecord to 'failed'. Default
# 1.5x is generous (tar.gz typically compresses to 50-80% of source).
# Raise for WAV-heavy projects that gzip poorly.
AVT_PAN_TMP_FREE_SPACE_RATIO=1.5

# Baidu Pan OAuth credentials (required when AVT_ENABLE_PAN_BACKUP=true)
# Obtain via https://pan.baidu.com/union/apply
AVT_BAIDU_PAN_APPKEY=
AVT_BAIDU_PAN_APPSECRET=
AVT_BAIDU_PAN_REDIRECT_URI=

# Fernet encryption key for OAuth tokens at rest (32B base64).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Loss = unrecoverable. Backup in 1Password + physical paper.
AVT_PAN_TOKEN_ENCRYPTION_KEY=

# --- Paddle MoR payment (gateway, plan 2026-06-08 P1) ---
# Default OFF. PaddleProvider stays non-operational until ENABLED=true AND the
# api key + webhook secret + all 6 price ids are set (graceful degrade — a
# half-configured Paddle simply doesn't appear as a checkout option).
AVT_PADDLE_ENABLED=false
# sandbox | production. R9: P1 runs against sandbox first.
AVT_PADDLE_ENV=sandbox
# Server-side API key — NEVER expose to the frontend. Needs transaction
# read+write (checkout) + price.read + notification_setting.read (verify/drift).
AVT_PADDLE_API_KEY=
# Notification destination signing secret (pdl_ntfset_...); verifies webhooks.
AVT_PADDLE_WEBHOOK_SECRET=
# Must match the Paddle dashboard notification destination URL exactly.
AVT_PADDLE_NOTIFY_URL=https://aitrans.video/api/billing/webhooks/paddle
# Webhook signature freshness window (seconds). Paddle SDK default is 5s; we
# widen for clock skew — the DB (provider, event_id) unique index is the
# primary replay guard, so a wider window here is defense-in-depth.
AVT_PADDLE_SIGNATURE_MAX_AGE_S=300
# The 6 one-time CNY price ids (from the Paddle dashboard). All 6 required for
# the provider to be operational. Verified against plan_catalog when a checkout
# is created — a drifted amount refuses the checkout (R4).
AVT_PADDLE_PRICE_PLUS_M=
AVT_PADDLE_PRICE_PLUS_Q=
AVT_PADDLE_PRICE_PLUS_A=
AVT_PADDLE_PRICE_PRO_M=
AVT_PADDLE_PRICE_PRO_Q=
AVT_PADDLE_PRICE_PRO_A=

# --- Paddle.js frontend (Next.js build-time, PUBLIC) ---
# Client-side token (Paddle designs it to be browser-safe/public) + environment
# for the /paddle-checkout page. These ARE shipped in the client bundle — never
# put the server API key or webhook secret here. Build-arg, not runtime env.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox

# --- PayPal Orders v2 (overseas USD lane; plan 2026-06-26) ---
# Master switch. Unset/false => PayPalProvider.operational = False (hidden).
# Default-OFF; enable only after sandbox-verifying the full flow.
AVT_PAYPAL_ENABLED=false
# sandbox (api-m.sandbox.paypal.com) | live (api-m.paypal.com)
AVT_PAYPAL_ENV=sandbox
# REST app Client ID + Secret (server-only; NEVER ship to the frontend — there
# is no browser-safe PayPal token, unlike Paddle's client token).
AVT_PAYPAL_CLIENT_ID=
AVT_PAYPAL_SECRET=
# Webhook subscription id from the PayPal dashboard (hard gate: without it the
# online verify-webhook-signature call cannot run). Sandbox + live each have one.
AVT_PAYPAL_WEBHOOK_ID=
# Buyer return / cancel URLs (defaults target aitrans.video). The return URL is
# a gateway endpoint that captures + settles; PayPal appends its own token.
AVT_PAYPAL_RETURN_URL=https://aitrans.video/api/billing/paypal/return
AVT_PAYPAL_CANCEL_URL=https://aitrans.video/settings/billing?provider=paypal&status=cancelled
# USD prices are NOT set here — they live in the admin pricing page
# (pricing_runtime.json plans.*.price_usd_cents). No CNY->USD rate env (option c).
# Frontend: no NEXT_PUBLIC_PAYPAL_* — PayPal carries no browser-safe credential.

# --- WeChat Pay v3 Native (own merchant, Rail 1; plan 2026-05-22) ---
# Master switch. Unset/false => WechatPayProvider.operational = False (hidden).
AVT_WECHATPAY_ENABLED=false
# Merchant identity (mchid shared with AiPlay.video; out_trade_no prefix
# disambiguates: this project AVT_, AiPlay APV_/wv_).
WECHATPAY_MCHID=
# APIv3 key: exactly 32 chars (AES-256-GCM callback resource decryption).
WECHATPAY_APIV3_KEY=
# Merchant private key + certificate serial (request signing).
WECHATPAY_PRIVATE_KEY_PATH=/opt/aivideotrans/config/wechatpay/apiclient_key.pem
WECHATPAY_CERT_SERIAL=
# WeChat platform public key (callback verification, public-key mode).
WECHATPAY_PUB_KEY_ID=
WECHATPAY_PLATFORM_PUB_KEY_PATH=/opt/aivideotrans/config/wechatpay/pub_key.pem
# Per-request callback URL override (merchant-portal default is shared).
WECHATPAY_NOTIFY_URL=https://aitrans.video/api/billing/webhooks/wechatpay
# out_trade_no prefix (cross-project de-conflict on the shared mchid).
WECHATPAY_ORDER_PREFIX=AVT_
# Optional bound appid (AiPlay runs Native without one).
WECHATPAY_APPID=

# --- APF 匿名 Free 预览 (plan 2026-06-10 T1) ---
# 默认全部关闭，对生产零影响。
# 公网开启前置条件：T1–T9 全部合并 + HMAC secret 已配 + §5 成本数字已确认。
#
# 后端 env 开关（gateway service）
# 开启需同时配齐 anonymous_preview_hash_secret（≥32字节）；
# secret 缺失或过短时 startup_checks.validate_anonymous_preview_config()
# 会 CRITICAL log 并强制降级回 False（不崩容器）。
AVT_ENABLE_ANONYMOUS_PREVIEW=false
# HMAC-SHA256 密钥，对 scope_key (IP/device/source) 做不可逆哈希存 DB。
# 生成：python -c "import secrets; print(secrets.token_urlsafe(32))"
# 必须 ≥32 字节；缺失时 enable_anonymous_preview 自动降级为 false。
AVT_ANONYMOUS_PREVIEW_HASH_SECRET=

# 前端 Next.js 构建时烘焙（build arg，默认 0 = 关）
# 开启后渲染"立即试用"入口及预览播放器。
# 注意：此值在 docker-compose build 时烘焙进 client bundle，改后需重建镜像。
NEXT_PUBLIC_ENABLE_ANONYMOUS_PREVIEW=0
